# Copy this file to ".env" and paste your key in.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model writes the quests. Defaults to claude-sonnet-4-6 (cheaper,
# for dev/validation). Set to claude-opus-4-8 for top-quality production output.
DAYQUEST_MODEL=claude-sonnet-4-6
