# Copy this file to ".env" and paste your key in.
# Get a key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Which Claude model writes the quests. Defaults to claude-sonnet-4-6 (cheaper,
# for dev/validation). Set to claude-opus-4-8 for top-quality production output.
DAYQUEST_MODEL=claude-sonnet-4-6

# --- POI database (Supabase) — OPTIONAL --------------------------------------
# When BOTH are set, quest generation reads curated APPROVED places from the DB
# (a first-class source alongside Wikipedia/OSM/Places) AND write-throughs every
# freshly-discovered place back as `pending` — so the pool grows with real usage.
# Unset (the default), the app runs exactly as before on live web sources only.
# Use the service_role key (bypasses RLS to write pending rows). Set up the table
# with db/poi_schema.sql, then: `npm install` at the repo root.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
