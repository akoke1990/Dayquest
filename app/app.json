{
  "expo": {
    "name": "DayQuest",
    "slug": "dayquest",
    "version": "1.0.0",
    "scheme": "dayquest",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DayQuest uses your location to find a scavenger hunt nearby."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "DayQuest uses your camera so you can photograph each stop on your quest.",
          "photosPermission": "DayQuest accesses your photos so you can pick an image for a stop."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "DayQuest uses your camera so you can catch the collectible waiting at each place you discover."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akoke18.dayquest",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "SUPABASE_URL": "https://xoonknhsurzwwahfhnjy.supabase.co",
      "SUPABASE_ANON_KEY": "sb_publishable_oekh-4raDYaxlNsLqhOylQ_WwwF-AGE",
      "GOOGLE_MAPS_API_KEY": "",
      "eas": {
        "projectId": "d590e873-0a0e-4d25-a78f-32478af4a91f"
      }
    }
  }
}
