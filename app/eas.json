{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_APP_REVIEW_CAPABLE": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_APP_REVIEW_CAPABLE": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_APP_REVIEW_CAPABLE": "false"
      }
    },
    "app-review": {
      "extends": "production",
      "distribution": "store",
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_APP_REVIEW_CAPABLE": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
