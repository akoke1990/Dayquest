{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dayquest.app/schemas/content-bank/v1.0.0",
  "title": "DayQuest NYC content bank v1",
  "description": "Authoring contract only. All published clues share one quality bar.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "site_id",
    "places",
    "hunt_ideas",
    "clue_packages"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "site_id": {
      "const": "nyc"
    },
    "places": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/place"
      }
    },
    "hunt_ideas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hunt_idea"
      }
    },
    "clue_packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clue_package"
      }
    }
  },
  "$defs": {
    "lifecycle": {
      "type": "string",
      "enum": [
        "candidate",
        "needs_source_review",
        "needs_field_verification",
        "field_verified",
        "published",
        "retired"
      ]
    },
    "category": {
      "type": "string",
      "description": "Primary observable target type; balance categories rather than defaulting to historical sites.",
      "enum": [
        "architecture",
        "gallery",
        "historic_site",
        "infrastructure",
        "landmark",
        "monument_memorial",
        "museum",
        "other",
        "park_garden",
        "public_art",
        "religious",
        "shop_market",
        "venue_nightlife"
      ]
    },
    "tri_state": {
      "type": "string",
      "enum": [
        "yes",
        "no",
        "unknown"
      ]
    },
    "editorial_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer",
        "reviewed_at",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_started",
            "in_progress",
            "approved",
            "changes_requested"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "reviewed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "field_review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reviewer",
        "verified_at",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_started",
            "in_progress",
            "approved",
            "changes_requested"
          ]
        },
        "reviewer": {
          "type": [
            "string",
            "null"
          ]
        },
        "verified_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "delivery_control": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canary_eligible",
        "paused"
      ],
      "properties": {
        "canary_eligible": {
          "type": "boolean",
          "description": "Explicit opt-in for field-verified canary delivery; never inferred from candidate state."
        },
        "paused": {
          "type": "boolean",
          "description": "Immediate delivery pause without changing immutable record identity."
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "provider",
        "external_id",
        "url",
        "license",
        "review_status",
        "excerpt"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^source:[a-z0-9._%~-]+:.+$"
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "external_id": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "review_status": {
          "enum": [
            "unreviewed",
            "reviewed",
            "rejected"
          ]
        },
        "excerpt": {
          "type": [
            "string",
            "null"
          ],
          "description": "Preserved context, never automatic observable evidence."
        }
      }
    },
    "observable_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence_id",
        "claim",
        "observable_target",
        "source_ids",
        "viewpoint",
        "stability",
        "seasonality",
        "verification"
      ],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^evidence:[a-z0-9._%~-]+:[a-z0-9._~-]+$"
        },
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "observable_target": {
          "enum": [
            "object",
            "artwork",
            "facade",
            "material",
            "shape",
            "signage",
            "streetscape",
            "landscape",
            "view",
            "spatial_relationship",
            "movement",
            "light",
            "other"
          ]
        },
        "source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "viewpoint": {
          "type": "string",
          "minLength": 1
        },
        "stability": {
          "enum": [
            "stable",
            "seasonal",
            "volatile",
            "unknown"
          ]
        },
        "seasonality": {
          "type": [
            "string",
            "null"
          ]
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "method",
            "verified_by",
            "verified_at"
          ],
          "properties": {
            "status": {
              "enum": [
                "unverified",
                "source_verified",
                "field_verified",
                "rejected"
              ]
            },
            "method": {
              "enum": [
                null,
                "source_review",
                "authoritative_current_image",
                "human_site_check"
              ]
            },
            "verified_by": {
              "type": [
                "string",
                "null"
              ]
            },
            "verified_at": {
              "type": [
                "string",
                "null"
              ],
              "format": "date-time"
            }
          }
        }
      }
    },
    "place": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_version",
        "lifecycle",
        "name",
        "location",
        "category",
        "tags",
        "aliases",
        "prohibited_aliases",
        "observable_evidence",
        "viewpoint_approach",
        "access_safety_mobility",
        "seasonality",
        "sources",
        "legacy_editorial_context",
        "editorial_review",
        "field_review",
        "migration"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^place:[a-z0-9._%~-]+:.+$"
        },
        "record_version": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "delivery": {
          "$ref": "#/$defs/delivery_control"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "type": "object",
          "required": [
            "lat",
            "lng",
            "area"
          ],
          "properties": {
            "lat": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "lng": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            "area": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "prohibited_aliases": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "observable_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observable_evidence"
          }
        },
        "viewpoint_approach": {
          "type": "object",
          "required": [
            "public_approach",
            "exterior_visible",
            "requires_entry"
          ],
          "properties": {
            "public_approach": {
              "type": [
                "string",
                "null"
              ]
            },
            "exterior_visible": {
              "$ref": "#/$defs/tri_state"
            },
            "requires_entry": {
              "$ref": "#/$defs/tri_state"
            }
          }
        },
        "access_safety_mobility": {
          "type": "object",
          "required": [
            "step_free_approach",
            "hours_dependent",
            "purchase_required",
            "sensory_requirements",
            "safety_notes",
            "accessibility_notes"
          ],
          "properties": {
            "step_free_approach": {
              "$ref": "#/$defs/tri_state"
            },
            "hours_dependent": {
              "$ref": "#/$defs/tri_state"
            },
            "purchase_required": {
              "$ref": "#/$defs/tri_state"
            },
            "sensory_requirements": {
              "type": "array",
              "items": {
                "enum": [
                  "vision",
                  "color_distinction",
                  "small_text",
                  "hearing",
                  "touch",
                  "none"
                ]
              }
            },
            "safety_notes": {
              "type": [
                "string",
                "null"
              ]
            },
            "accessibility_notes": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "seasonality": {
          "type": "object",
          "required": [
            "availability",
            "notes"
          ],
          "properties": {
            "availability": {
              "enum": [
                "year_round",
                "seasonal",
                "temporary",
                "unknown"
              ]
            },
            "notes": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "legacy_editorial_context": {
          "type": "object"
        },
        "editorial_review": {
          "$ref": "#/$defs/editorial_review"
        },
        "field_review": {
          "$ref": "#/$defs/field_review"
        },
        "migration": {
          "type": "object",
          "required": [
            "importer",
            "source_file"
          ]
        }
      }
    },
    "hunt_idea": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_version",
        "lifecycle",
        "title",
        "concept",
        "place_ids",
        "observable_target_ids",
        "editorial_review",
        "field_review"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^idea:nyc:[a-z0-9._~-]+$"
        },
        "record_version": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "delivery": {
          "$ref": "#/$defs/delivery_control"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "concept": {
          "type": "string"
        },
        "place_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "observable_target_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "editorial_review": {
          "$ref": "#/$defs/editorial_review"
        },
        "field_review": {
          "$ref": "#/$defs/field_review"
        }
      }
    },
    "clue_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "record_version",
        "lifecycle",
        "place_id",
        "hunt_idea_id",
        "language",
        "clue",
        "hints",
        "evidence_refs",
        "editorial_review",
        "field_review"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^clue:nyc:[a-z0-9._~-]+:[a-z0-9._~-]+$"
        },
        "record_version": {
          "type": "integer",
          "minimum": 1
        },
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "delivery": {
          "$ref": "#/$defs/delivery_control"
        },
        "place_id": {
          "type": "string"
        },
        "hunt_idea_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "clue": {
          "type": "string"
        },
        "hints": {
          "type": "array",
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rung",
              "text",
              "evidence_refs"
            ],
            "properties": {
              "rung": {
                "type": "integer",
                "minimum": 1,
                "maximum": 3
              },
              "text": {
                "type": "string"
              },
              "evidence_refs": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "evidence_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "editorial_review": {
          "$ref": "#/$defs/editorial_review"
        },
        "field_review": {
          "$ref": "#/$defs/field_review"
        }
      }
    }
  }
}
